{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "leo-agile-builder configuration",
  "type": "object",
  "required": ["sprintHistory", "roles", "artifacts"],
  "properties": {
    "sprintHistory": {
      "type": "object",
      "required": ["recentCount", "tokenBudget", "alwaysIncludeDomains"],
      "properties": {
        "recentCount": {
          "type": "integer",
          "minimum": 0
        },
        "tokenBudget": {
          "type": "integer",
          "minimum": 1
        },
        "alwaysIncludeDomains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "roles": {
      "type": "object",
      "required": ["pm", "architect", "developer", "qa-reviewer"],
      "properties": {
        "pm": {
          "type": "string"
        },
        "architect": {
          "type": "string"
        },
        "developer": {
          "type": "string"
        },
        "qa-reviewer": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["sprintsDir", "files"],
      "properties": {
        "sprintsDir": {
          "type": "string"
        },
        "files": {
          "type": "object",
          "required": [
            "prd",
            "design",
            "implementation",
            "review",
            "retro",
            "meta"
          ],
          "properties": {
            "prd": {
              "type": "string"
            },
            "design": {
              "type": "string"
            },
            "implementation": {
              "type": "string"
            },
            "review": {
              "type": "string"
            },
            "retro": {
              "type": "string"
            },
            "meta": {
              "type": "string"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
